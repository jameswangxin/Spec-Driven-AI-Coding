{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/workflow/capability.schema.json",
  "title": "Workflow Capability Frontmatter",
  "type": "object",
  "required": [
    "id",
    "title",
    "status",
    "introduced_by",
    "updated_by"
  ],
  "additionalProperties": true,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^CAP-[0-9]{4}$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "active",
        "deprecated",
        "superseded"
      ]
    },
    "introduced_by": {
      "type": "string",
      "pattern": "^REQ-[0-9]{4}$"
    },
    "updated_by": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^REQ-[0-9]{4}$"
      },
      "uniqueItems": true
    }
  }
}
