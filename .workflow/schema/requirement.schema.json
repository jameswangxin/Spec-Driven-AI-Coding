{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/workflow/requirement.schema.json",
  "title": "Workflow Requirement Frontmatter",
  "type": "object",
  "required": [
    "id",
    "title",
    "status",
    "complexity",
    "risk_tags",
    "plan_required",
    "plan_reason",
    "created_at",
    "updated_at",
    "references",
    "capabilities",
    "history"
  ],
  "additionalProperties": true,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^REQ-[0-9]{4}$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "accepted",
        "planned",
        "implemented",
        "verified",
        "archived",
        "blocked",
        "canceled",
        "reopened",
        "superseded"
      ]
    },
    "complexity": {
      "type": "string",
      "enum": [
        "simple",
        "medium",
        "complex"
      ]
    },
    "risk_tags": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "data",
          "security",
          "migration",
          "external-api",
          "architecture",
          "cross-module"
        ]
      },
      "uniqueItems": true
    },
    "plan_required": {
      "type": "boolean"
    },
    "plan_reason": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "updated_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "references": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^CAP-[0-9]{4}$"
      }
    },
    "owner": {
      "type": [
        "string",
        "null"
      ]
    },
    "reviewers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "approvers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "history": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "date",
          "from",
          "to",
          "note"
        ],
        "additionalProperties": false,
        "properties": {
          "date": {
            "type": "string",
            "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
          },
          "from": {
            "type": [
              "string",
              "null"
            ]
          },
          "to": {
            "type": "string"
          },
          "note": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
